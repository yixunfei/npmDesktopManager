{
  "name": "npmDesktopManager",
  "version": "1.0.0",
  "description": "A graphical npm package manager for desktop",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "build:icons": "node scripts/generate-icons-simple.js icon.jpg",
    "build:win": "node scripts/build.js win all",
    "build:win-installer": "node scripts/build.js win installer",
    "build:win-portable": "node scripts/build.js win portable",
    "build:mac": "node scripts/build.js mac all",
    "build:mac-dmg": "node scripts/build.js mac installer",
    "build:mac-zip": "node scripts/build.js mac portable",
    "build:linux": "node scripts/build.js linux all",
    "build:linux-appimage": "node scripts/build.js linux portable",
    "build:linux-deb": "node scripts/build.js linux installer",
    "build:all": "node scripts/build.js all all",
    "release": "node scripts/release.js current",
    "release:all": "node scripts/release.js all"
  },
  "keywords": [
    "npm",
    "manager",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "antd": "^6.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "semver": "^7.8.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.5.6",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "build": {
    "appId": "com.npm.desktop.manager",
    "productName": "npmDesktopManager",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "icon.jpg"
    ],
    "extraResources": [
      {
        "from": "icon.jpg",
        "to": "icon.jpg"
      }
    ],
    "win": {
      "icon": "icon.jpg",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "icon.jpg",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "icon.jpg",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "displayLanguageSelector": true,
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ],
      "language": "1033",
      "deleteAppDataOnUninstall": false
    }
  }
}
